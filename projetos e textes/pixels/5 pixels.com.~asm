; a short program to check how
; set and get pixel color works

name "pixel"

org  100h

;primeiro pixel

mov ah, 0   ; set display mode function.
mov al,13h  ; mode 13h = 320x200 pixels, 256 colors.
int 10h     ; set it!

mov cx, 150 ; coluna
mov dx, 20  ; linha
mov al, 128 ; cor do pixel
mov ah, 0ch ; put pixel
int 10h

xor al, al  ; al = 0

mov cx, 20  ; coluna
mov dx, 20  ; linh
mov ah, 0dh ; get pixel
int 10h

;segundo pixel
mov cx, 150 ; columna
mov dx, 40  ; linha
mov al, 128 ; cor do pixel
mov ah, 0ch ; put pixel
int 10h

xor al, al  ; al = 0

mov cx, 20  ; columna
mov dx, 20  ; linha
mov ah, 0dh ; get pixel
int 10h

;terceiro pixel
mov cx, 150 ; coluna
mov dx, 60  ; linha
mov al, 128 ; cor do pixel
mov ah, 0ch ; put pixel
int 10h

xor al, al  ; al = 0

mov cx, 20  ; column
mov dx, 20  ; row
mov ah, 0dh ; get pixel
int 10h

;quarto pixel
mov cx, 150 ; coluna
mov dx, 80  ; linha
mov al, 128 ; cor do pixel
mov ah, 0ch ; put pixel
int 10h

xor al, al  ; al = 0

mov cx, 20  ; coluna
mov dx, 20  ; linha
mov ah, 0dh ; get pixel
int 10h


;quinto pixel
mov cx, 150 ; coluna
mov dx, 100 ; linha
mov al, 128 ; cor do pixel
mov ah, 0ch ; put pixel
int 10h

xor al, al  ; al = 0

mov cx, 20  ; coluna
mov dx, 20  ; linha
mov ah, 0dh ; get pixel
int 10h

; pause the screen for dos compatibility:

;wait for keypress
mov ah,00
int 16h

; return to text mode:
mov ah,00 ; set display mode function.
mov al,03 ; normal text mode 3
int 10h   ; set it!


ret



